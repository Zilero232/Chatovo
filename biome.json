{
  "$schema": "https://biomejs.dev/schemas/2.4.15/schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "includes": [
      "**",
      "!**/dist",
      "!apps/desktop",
      "!apps/client/src/app/router/route-tree.gen.ts",
      "!**/node_modules",
      "!apps/client/.tanstack"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100,
    "lineEnding": "lf"
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "jsxQuoteStyle": "double",
      "semicolons": "always",
      "trailingCommas": "all",
      "arrowParentheses": "always"
    }
  },
  "css": {
    "parser": {
      "tailwindDirectives": true
    }
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "style": {
        "noNonNullAssertion": "warn",
        "useImportType": "error",
        "noRestrictedImports": {
          "level": "error",
          "options": {
            "paths": {
              "@/features/*/ui/*": "Import via barrel: '@/features/<slice>'",
              "@/features/*/model/*": "Import via barrel: '@/features/<slice>'",
              "@/features/*/api/*": "Import via barrel: '@/features/<slice>'",
              "@/widgets/*/ui/*": "Import via barrel: '@/widgets/<slice>'",
              "@/widgets/*/model/*": "Import via barrel: '@/widgets/<slice>'",
              "@/entities/*/ui/*": "Import via barrel: '@/entities/<slice>'",
              "@/entities/*/model/*": "Import via barrel: '@/entities/<slice>'",
              "@/pages/*/ui/*": "Import via barrel: '@/pages/<slice>'"
            }
          }
        }
      },
      "correctness": {
        "noUnusedImports": "error",
        "noUnusedVariables": "error"
      },
      "suspicious": {
        "noExplicitAny": "error"
      }
    }
  },
  "assist": {
    "enabled": true,
    "actions": {
      "source": {
        "organizeImports": "on"
      }
    }
  }
}
