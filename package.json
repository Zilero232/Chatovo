{
  "name": "chatovo",
  "version": "1.1.3",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "prepare": "husky",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "typecheck": "bun --filter @chatovo/schemas typecheck && bun --filter @chatovo/server typecheck && bun --filter @chatovo/client typecheck",
    "dev": "bun --filter '@chatovo/server' --filter '@chatovo/client' --parallel dev",
    "dev:client": "bun --filter @chatovo/client dev",
    "dev:server": "bun --filter @chatovo/server dev",
    "dev:livekit": "docker compose -f docker-compose.dev.yml up",
    "dev:full": "docker compose -f docker-compose.dev.yml up -d && bun dev",
    "build": "bun --filter @chatovo/server build && bun --filter @chatovo/client build",
    "tauri": "bun --filter @chatovo/tauri tauri",
    "tauri:dev": "bun --filter '@chatovo/server' --filter '@chatovo/tauri' --parallel dev",
    "tauri:build": "bun --filter @chatovo/client build && bun --filter @chatovo/tauri build",
    "tauri:android:init": "bun --filter @chatovo/tauri android:init",
    "tauri:android:dev": "bun --filter @chatovo/tauri android:dev",
    "tauri:android:build": "bun --filter @chatovo/client build && bun --filter @chatovo/tauri android:build:aab"
  },
  "dependencies": {
    "babel-plugin-react-compiler": "^1.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.16",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8"
  },
  "lint-staged": {
    "*": "biome check --write --no-errors-on-unmatched --files-ignore-unknown=true"
  }
}
