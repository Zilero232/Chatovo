{
  "name": "@chatovo/tauri",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "tauri": "tauri",
    "predev": "node ./scripts/kill-stale.mjs && bun run icon",
    "dev": "tauri dev",
    "build": "bun run icon && tauri build",
    "build:debug": "bun run icon && tauri build --debug",
    "android:init": "bun --env-file .env tauri android init",
    "android:dev": "bun run icon && bun --env-file .env tauri android dev",
    "android:build": "bun run icon && bun --env-file .env tauri android build",
    "android:build:aab": "bun run icon && bun --env-file .env tauri android build -- --aab",
    "info": "tauri info",
    "icon": "tauri icon ../client/app/icon.svg -o icons",
    "signer:sign": "tauri signer sign",
    "signer:generate": "tauri signer generate -w ~/.tauri/chatovo.key --password \"\""
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2"
  }
}
