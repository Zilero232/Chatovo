# Chatovo Tauri — Android build environment.
#
# Copy to `.env` and adjust paths for your machine:
#   cp apps/tauri/.env.example apps/tauri/.env
#
# Loaded automatically by android:* scripts via `bun --env-file .env`.
#
# Required in Android Studio → SDK Manager → SDK Tools (all must be checked):
#   - Android SDK Command-line Tools (latest)  ← required for `tauri android init`
#   - Android SDK Build-Tools
#   - Android SDK Platform-Tools
#   - Android SDK Platform (e.g. Android 14 / API 34+)
#   - NDK (Side by side)
#
# After install, verify folders exist:
#   %ANDROID_HOME%\cmdline-tools\latest\bin\sdkmanager.bat
#   %ANDROID_HOME%\ndk\<version>\

JAVA_HOME=C:\Program Files\Android\Android Studio\jbr
ANDROID_HOME=C:\Users\React\AppData\Local\Android\Sdk
NDK_HOME=C:\Users\React\AppData\Local\Android\Sdk\ndk\27.2.12479018

# Set NDK_HOME to the folder name you actually have under ndk\ (not a guess).
# List installed packages:
#   "%ANDROID_HOME%\cmdline-tools\latest\bin\sdkmanager.bat" --list_installed
