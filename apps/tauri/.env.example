# Chatovo Tauri — local Android / desktop build environment.
#
#   cp apps/tauri/.env.example apps/tauri/.env
#
# Loaded by android:* scripts via `bun --env-file .env`.
# Client bundle (NEXT_PUBLIC_*) → apps/client/.env (see that file).

# --- Android SDK (local machine paths) ---

JAVA_HOME=C:\Program Files\Android\Android Studio\jbr
ANDROID_HOME=C:\Users\React\AppData\Local\Android\Sdk
NDK_HOME=C:\Users\React\AppData\Local\Android\Sdk\ndk\27.2.12479018

# Android Studio → SDK Manager → SDK Tools:
# Command-line Tools, Build-Tools, Platform-Tools, Platform (API 34+), NDK.

# --- Android release signing ---
#
# 1) Create keystore (once, run from the folder where you want the file):
#
#   Windows (Android Studio JBR — adjust path if Studio is installed elsewhere):
#   & "C:\Program Files\Android\Android Studio\jbr\bin\keytool.exe" -genkey -v -keystore chatovo-release.keystore -alias chatovo -keyalg RSA -keysize 2048 -validity 10000
#
#   Or if JAVA_HOME is set (see below):
#   & "$env:JAVA_HOME\bin\keytool.exe" -genkey -v -keystore chatovo-release.keystore -alias chatovo -keyalg RSA -keysize 2048 -validity 10000
#
#   macOS / Linux:
#   keytool -genkey -v -keystore chatovo-release.keystore -alias chatovo -keyalg RSA -keysize 2048 -validity 10000
#
# Remember: alias = chatovo, and the password you type twice.
#
# 2) Fill in below for local reference / manual gen/android setup:
#
# ANDROID_KEY_ALIAS     → alias from keytool (chatovo)
# ANDROID_KEY_PASSWORD  → keystore password from step 1
# ANDROID_KEYSTORE_PATH → full path to chatovo-release.keystore
#
# 3) For GitHub Actions — same alias/password, plus base64 of the file:
#
#   PowerShell:
#   [Convert]::ToBase64String([IO.File]::ReadAllBytes("C:\path\to\chatovo-release.keystore"))
#
#   Paste output into GitHub → Settings → Secrets → ANDROID_KEY_BASE64
#   (do NOT commit base64 into .env)

ANDROID_KEY_ALIAS=chatovo
ANDROID_KEY_PASSWORD=
ANDROID_KEYSTORE_PATH=C:\path\to\chatovo-release.keystore

# --- Tauri desktop updater (local desktop release only) ---
#
#   bun --filter @chatovo/tauri signer:generate
# GitHub secret: TAURI_SIGNING_PRIVATE_KEY

# TAURI_SIGNING_PRIVATE_KEY=

# --- GitHub Actions secrets (copy values, not this file) ---
#
# deploy-web.yml + release-app.yml:
#
#   NEXT_PUBLIC_API_URL=https://api.chatovo.ru
#   NEXT_PUBLIC_LIVEKIT_URL=wss://livekit.chatovo.ru
#   TAURI_SIGNING_PRIVATE_KEY=<from tauri signer generate>
#   ANDROID_KEY_ALIAS=chatovo
#   ANDROID_KEY_PASSWORD=<keystore password>
#   ANDROID_KEY_BASE64=<base64 from PowerShell command above>
#
# deploy-web.yml only: SSH_HOST, SSH_USER, SSH_PRIVATE_KEY, DEPLOY_PATH
