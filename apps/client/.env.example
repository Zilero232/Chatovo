# Chatovo web client — environment template.
#
# Copy this file to `.env` and fill in real values:
#   cp apps/client/.env.example apps/client/.env
#
# NEXT_PUBLIC_* values are baked into the build at `next build` time and are
# visible in the browser bundle — never put secrets here.
#
# The SAME file name `.env` is used for local dev, the production web build,
# and the Tauri desktop build. Only the VALUES differ. `.env` is git-ignored.

# API base URL — the Hono server, on its own subdomain.
#   - local dev, direct:   http://localhost:4000
#   - local dev via Caddy: https://api.chatovo.localhost  (docker-compose.dev.yml
#                          — mirrors the prod cross-origin / proxy / HTTPS layer)
#   - production website:  https://api.chatovo.ru  (cross-origin to chatovo.ru —
#                          server CORS allows it via CORS_ORIGINS)
#   - Tauri desktop build: https://api.chatovo.ru  (same as web — Tauri origin
#                          is tauri://localhost and is always CORS-allowed)
#   - Tauri Android emulator: localhost / *.localhost are rewritten to 10.0.2.2
#                          at runtime — keep API on http://localhost:4000 in .env
#   - Tauri Android release build on a real phone: production URLs below
#
# Local dev:
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_LIVEKIT_URL=wss://livekit.chatovo.ru
#
# Release APK / CI (uncomment for device build or use same values in GitHub Secrets):
# NEXT_PUBLIC_API_URL=https://api.chatovo.ru
# NEXT_PUBLIC_LIVEKIT_URL=wss://livekit.chatovo.ru
