{
  "name": "@chatovo/server",
  "type": "module",
  "version": "0.0.0",
  "private": true,
  "main": "src/main.ts",
  "scripts": {
    "predev": "node ./scripts/kill-port.mjs",
    "dev": "bun --hot --cwd ../.. --env-file apps/server/.env apps/server/src/main.ts",
    "start": "bun src/main.ts",
    "build": "bun build src/main.ts --target=bun --outdir=dist --packages external",
    "db:push": "prisma db push && prisma generate",
    "db:migrate": "prisma migrate dev && prisma generate",
    "db:deploy": "prisma migrate deploy",
    "db:status": "prisma migrate status",
    "db:reset": "prisma migrate reset",
    "db:format": "prisma format",
    "db:studio": "prisma studio",
    "db:generate": "prisma generate",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "typecheck": "tsc --noEmit",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@chatovo/schemas": "workspace:*",
    "@grammyjs/parse-mode": "^2.3.0",
    "@nestjs/common": "11.1.28",
    "@nestjs/config": "4.0.4",
    "@nestjs/core": "11.1.28",
    "@nestjs/event-emitter": "3.1.0",
    "@nestjs/platform-express": "11.1.28",
    "@nestjs/platform-ws": "11.1.28",
    "@nestjs/serve-static": "5.0.5",
    "@nestjs/swagger": "11.4.5",
    "@nestjs/terminus": "11.1.1",
    "@nestjs/throttler": "6.5.0",
    "@nestjs/websockets": "11.1.28",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@react-email/render": "^2.1.0",
    "@thallesp/nestjs-better-auth": "2.7.0",
    "better-auth": "^1.6.23",
    "express": "5.2.1",
    "firebase-admin": "^14.1.0",
    "grammy": "^1.44.0",
    "helmet": "8.3.0",
    "livekit-server-sdk": "^2.17.0",
    "mime-types": "^3.0.2",
    "nestjs-pino": "4.6.1",
    "nestjs-zod": "5.4.0",
    "nodemailer": "^9.0.3",
    "pg": "^8.22.0",
    "pino": "10.3.1",
    "pino-http": "11.0.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-email": "^6.8.1",
    "reflect-metadata": "0.2.2",
    "remeda": "^2.39.0",
    "rxjs": "7.8.2",
    "ts-pattern": "^5.9.0",
    "ws": "8.21.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/express": "^5.0.6",
    "@types/mime-types": "^3.0.1",
    "@types/multer": "^2.2.0",
    "@types/nodemailer": "^8.0.1",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "dotenv": "^17.4.2",
    "pino-pretty": "^13.1.3",
    "prisma": "^7.8.0",
    "typescript": "~6.0.3"
  }
}
