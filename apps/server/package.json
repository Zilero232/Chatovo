{
  "name": "@chatovo/server",
  "type": "module",
  "version": "0.0.0",
  "private": true,
  "main": "src/index.ts",
  "scripts": {
    "predev": "node ./scripts/kill-port.mjs",
    "dev": "bun --hot --cwd ../.. --env-file apps/server/.env apps/server/src/index.ts",
    "start": "bun src/index.ts",
    "build": "bun build src/index.ts --target=bun --outdir=dist --external @better-auth/kysely-adapter --external kysely",
    "db:push": "prisma db push && prisma generate",
    "db:migrate": "prisma migrate dev && prisma generate",
    "db:deploy": "prisma migrate deploy",
    "db:status": "prisma migrate status",
    "db:reset": "prisma migrate reset",
    "db:format": "prisma format",
    "db:studio": "prisma studio",
    "db:generate": "prisma generate",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "typecheck": "tsc --noEmit",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@chatovo/schemas": "workspace:*",
    "@grammyjs/parse-mode": "^2.3.0",
    "@hono/swagger-ui": "^0.6.1",
    "@hono/zod-openapi": "^1.4.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@prisma/client-runtime-utils": "^7.8.0",
    "@react-email/render": "^2.0.9",
    "better-auth": "^1.6.23",
    "grammy": "^1.44.0",
    "hono": "^4.12.27",
    "http-status-codes": "^2.3.0",
    "livekit-server-sdk": "^2.16.0",
    "mime-types": "^3.0.2",
    "nodemailer": "^9.0.3",
    "pg": "^8.22.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-email": "^6.6.5",
    "remeda": "^2.39.0",
    "ts-pattern": "^5.9.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/mime-types": "^3.0.1",
    "@types/nodemailer": "^8.0.1",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "dotenv": "^17.4.2",
    "prisma": "^7.8.0",
    "typescript": "~6.0.3"
  }
}
