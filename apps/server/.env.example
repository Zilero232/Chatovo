# Chatovo API server — environment template.
#
# Copy this file to `.env` and fill in real values:
#   cp apps/server/.env.example apps/server/.env
#
# The SAME file name `.env` is used everywhere:
#   - locally:  read by `bun dev` (see package.json)
#   - on VPS:   loaded into the Docker container (see docker-compose.yml)
# Only the VALUES differ between dev and prod. `.env` is git-ignored;
# this `.env.example` is the only env file committed to the repo.

# `development` locally, `production` on the VPS.
NODE_ENV=development
PORT=4000

# Allowed web client origin(s), comma-separated.
# Production: the API lives on a separate subdomain (api.chatovo.ru) from the
# website (chatovo.ru), so the browser does send CORS preflight requests.
# Put the website origin here. Tauri origins (tauri://localhost) are always
# allowed automatically — no need to list them.
#
# Values per environment:
#   - VPS:               CORS_ORIGINS=https://chatovo.ru
#   - local, direct:     CORS_ORIGINS=http://localhost:3000
#   - local, via Caddy:  CORS_ORIGINS=https://chatovo.localhost
#     (docker-compose.dev.yml — mirrors the prod cross-origin + HTTPS layer)
CORS_ORIGINS=http://localhost:3000

# --- Auth (better-auth) ---
# Secret used to sign/encrypt tokens. Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=replace-with-a-long-random-secret

# Public base URL of THIS API server (where /auth/* is mounted).
#   - local dev:  http://localhost:4000
#   - production: https://api.chatovo.ru
BETTER_AUTH_URL=http://localhost:4000

# Optional extra allowedHosts for better-auth in development (comma-separated).
# Use when testing on a physical Android device with `tauri android dev --host <LAN_IP>`:
#   AUTH_DEV_ALLOWED_HOSTS=192.168.1.7:*
AUTH_DEV_ALLOWED_HOSTS=

# --- Email (SMTP) ---
# Powers signup email verification, change-email confirmation, and password
# reset. Any SMTP server works — set the values for your provider below.
#
#   Yandex 360 for business:  SMTP_HOST=smtp.yandex.ru  SMTP_PORT=465  SMTP_SECURE=true
#     SMTP_USER / SMTP_PASSWORD = mailbox address + an app password
#     (Yandex ID → Security → App passwords; the account password won't work).
#   Mail.ru for business:     SMTP_HOST=smtp.mail.ru    SMTP_PORT=465  SMTP_SECURE=true
#   STARTTLS instead of TLS:  SMTP_PORT=587  SMTP_SECURE=false
#
# Deliverability — messages reach Gmail/Outlook/any inbox ONLY if:
#   - The EMAIL_FROM address equals SMTP_USER. Yandex (and most providers)
#     reject "From" addresses you're not logged in as: "Sender address
#     rejected: not owned by auth user". The display name can be anything;
#     the address in <...> must match SMTP_USER.
#   - SPF, DKIM and DMARC DNS records exist for the sending domain (your mail
#     provider gives the exact values). Without them Gmail/mail.ru/yandex
#     drop the messages into spam or reject them outright.
#   - The From domain matches the DKIM-signed domain. Keep EMAIL_FROM,
#     BETTER_AUTH_URL and the client origin on one root domain (e.g.
#     @chatovo.ru + api.chatovo.ru) so links match the sender.
SMTP_HOST=smtp.yandex.ru
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=noreply@chatovo.ru
SMTP_PASSWORD=your-app-password
EMAIL_FROM=Chatovo <noreply@chatovo.ru>

# Address that receives user bug reports / feedback ("Report a problem").
SUPPORT_EMAIL=zilero@chatovo.ru

# Dev-only: redirect every outgoing email to this address so you don't email
# real users while testing. Omit in production.
# DEV_EMAIL_OVERRIDE=you@example.com

# --- File uploads (local disk, served under /uploads) ---
# Directory where avatars + chat attachments are written. In Docker this is a
# mounted volume (see docker-compose.yml).

UPLOADS_DIR=./uploads
# Public origin files are served from (used to build absolute URLs in the DB).
#   - local dev:  http://localhost:4000
#   - production: https://api.chatovo.ru
PUBLIC_FILES_URL=http://localhost:4000

# --- LiveKit ---
# Options — pick one and use matching values everywhere:
#   a) LiveKit Cloud:        LIVEKIT_URL=wss://<project>.livekit.cloud
#   b) Self-hosted VPS:      LIVEKIT_URL=wss://livekit.chatovo.ru
#   c) Local dev SFU:        LIVEKIT_URL=ws://localhost:7880
#   d) Local dev via Caddy:  LIVEKIT_URL=ws://localhost:7880
#      (server still talks to the SFU directly; only the browser goes
#      through Caddy at ws://livekit.chatovo.localhost — see the client .env)
#
# The API key and secret MUST match the LiveKit side: the LiveKit Cloud
# dashboard (a), livekit.yaml on the VPS (b), or livekit.dev.yaml in the repo
# root (c). The browser never sees the secret — the server signs JWTs with it.
#
# Webhooks (live presence panel) only reach the API if LiveKit can POST to it.
# Cloud/VPS LiveKit cannot reach your localhost — for that use the local dev
# SFU (c): see infra/livekit/README.md → "Local development".
#
# Local dev (c) values: LIVEKIT_API_KEY=devkey, LIVEKIT_URL=ws://localhost:7880,
# LIVEKIT_API_SECRET=devsecret_devsecret_devsecret_32
LIVEKIT_API_KEY=API...
LIVEKIT_API_SECRET=...
LIVEKIT_URL=wss://livekit.chatovo.ru

# --- Telegram notifications (optional) ---
# Sends a message to a fixed chat whenever someone joins a voice channel.
# Leave both unset to disable the feature entirely (no-op, nothing breaks).
#   - TELEGRAM_BOT_TOKEN: create a bot via @BotFather, copy the token.
#   - TELEGRAM_CHAT_ID:   your chat id. Message the bot once, then open
#     https://api.telegram.org/bot<token>/getUpdates and read result[].message.chat.id
#     (a negative number for groups). For groups, add the bot to the group first.
# TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
# TELEGRAM_CHAT_ID=123456789
#
#   - TELEGRAM_PROXY_URL: outbound proxy for api.telegram.org, for hosts that
#     cannot reach the Bot API directly (e.g. RU datacenters). Unset = direct.
#     Must be an http(s):// proxy — the Bun runtime's fetch does not support
#     socks5://.
#
#     Set it up on a node that CAN reach Telegram (your own VPS / VPN endpoint
#     abroad):
#       1. Install an HTTP proxy:
#            apt install -y tinyproxy
#       2. /etc/tinyproxy/tinyproxy.conf — bind a port, whitelist this API
#          server's IP, allow HTTPS CONNECT:
#            Port 8888
#            Allow <THIS_SERVER_IP>
#            ConnectPort 443
#          then: systemctl restart tinyproxy
#       3. Open the port to this API server only (allow SSH first so you don't
#          lock yourself out):
#            ufw allow 22/tcp
#            ufw allow from <THIS_SERVER_IP> to any port 8888 proto tcp
#       4. Set the var below, then recreate the container:
#            docker compose up -d --force-recreate server
# TELEGRAM_PROXY_URL=http://proxy-host:8888

# --- Database (self-hosted Postgres) ---
# POSTGRES_* are read by the postgres container in docker-compose.yml.
POSTGRES_USER=chatovo
POSTGRES_PASSWORD=replace-with-a-strong-password
POSTGRES_DB=chatovo

#
# Connection string used by Prisma + better-auth at runtime.
#   - in Docker:  host is the compose service name `postgres`
#   - local dev:  host is `localhost` and the port is published
# DATABASE_URL and DIRECT_URL are the same for a self-hosted single instance.
DATABASE_URL="postgresql://chatovo:replace-with-a-strong-password@postgres:5432/chatovo"
DIRECT_URL="postgresql://chatovo:replace-with-a-strong-password@postgres:5432/chatovo"
